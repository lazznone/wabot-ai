{
  "name": "wabot-ai",
  "version": "1.0.0",
  "description": "WhatsApp AI Agent Bot - Modular, Scalable, Production-Ready",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:lowspec": "NODE_ENV=lowspec node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "db:migrate": "ts-node src/database/migrate.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.3",
    "jimp": "^0.22.12",
    "axios": "^1.7.2",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "crypto-js": "^4.2.0",
    "qrcode": "^1.5.3",
    "ws": "^8.17.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "rate-limiter-flexible": "^5.0.3",
    "uuid": "^10.0.0",
    "dayjs": "^1.11.11",
    "pino": "^9.2.0",
    "fastq": "^1.17.1",
    "lru-cache": "^11.0.0",
    "openai": "^4.52.7",
    "@google/generative-ai": "^0.15.0",
    "@anthropic-ai/sdk": "^0.26.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.11",
    "@types/ws": "^8.5.11",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.3",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "eslint": "^9.6.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
